# Modèle de configuration — copier vers .env.local et remplir les valeurs.
# .env.local ne doit JAMAIS être commité (déjà ignoré par .gitignore).
# En production (Vercel) : Project → Settings → Environment Variables.

# ── Supabase (base de données + authentification) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Replicate (pipeline IA) ──
REPLICATE_API_TOKEN=r8_your-replicate-api-token
# Modèle img2img custom (format "compte/modele:HASH_DE_VERSION") + trigger LoRA
REPLICATE_IMG2IMG_MODEL=
REPLICATE_LORA_TRIGGER=

# Réglages de génération — reporte ici les valeurs testées sur le playground
# replicate.com (laisser vide = valeurs par défaut du code)
REPLICATE_PROMPT_STRENGTH=
REPLICATE_NUM_INFERENCE_STEPS=
REPLICATE_GUIDANCE_SCALE=
REPLICATE_OUTPUT_QUALITY=
REPLICATE_LORA_SCALE=

# ── Stripe (paiements & abonnements) ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Price IDs des abonnements (créer dans Stripe Dashboard)
STRIPE_PRICE_ESSENTIEL_MONTHLY=price_
STRIPE_PRICE_ESSENTIEL_YEARLY=price_
STRIPE_PRICE_PRO_MONTHLY=price_
STRIPE_PRICE_PRO_YEARLY=price_
STRIPE_PRICE_ULTRA_MONTHLY=price_
STRIPE_PRICE_ULTRA_YEARLY=price_

# Price IDs des packs de crédits à l'unité (top-up)
STRIPE_PRICE_CREDITS_800=price_
STRIPE_PRICE_CREDITS_2000=price_

# ── Google OAuth (via Supabase — voir Authentication → Providers → Google) ──
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── App ──
# URL publique du site en développement (sur ta machine)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# URL du site en ligne (production)
NEXT_PUBLIC_SITE_URL=https://example.com
# Secret aléatoire (min. 32 caractères) — génère-en un avec : openssl rand -hex 32
API_SECRET_KEY=your-random-secret-key-min-32-chars

# ── Upload d'images ──
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
